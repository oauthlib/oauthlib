{
    "name": "OAuthLib full Development Container",
    "context": "..",
    "dockerFile": "Dockerfile",
    "postCreateCommand": "uvx pre-commit install && ln -sf /workspaces/oauthlib/.devcontainer/motd.sh ~/.oh-my-zsh/custom/motd.zsh",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            }
        }
    },
    "mounts": [
        "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,readonly,type=bind"
    ],
    "remoteEnv": {
        "SSH_AUTH_SOCK": "${localEnv:SSH_AUTH_SOCK}"
    }
}
